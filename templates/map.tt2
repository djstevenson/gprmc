<style>
.map-base {
  fill: #eee8db;
}

.road-major {
  fill: none;
  stroke: #e8a33d;
  stroke-width: 4;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.road-medium {
  fill: none;
  stroke: #ffffff;
  stroke-width: 3;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.road-minor {
  fill: none;
  stroke: #c7c0ac;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.place-label {
  font-family: sans-serif;
  fill: #4a4636;
  text-anchor: middle;
  stroke: #eee8db;
  stroke-width: 3px;
  paint-order: stroke;
}
</style>

[% heading = frame.direction || 0 %]

<svg viewBox="0 0 [% frame.map_width %] [% frame.map_height %]"
     width="[% frame.map_width %]" height="[% frame.map_height %]" role="img">

  <rect class="map-base" x="0" y="0" width="[% frame.map_width %]" height="[% frame.map_height %]"/>

  [% FOREACH line IN frame.map_lines %]
    <polyline class="[% line.class %]" points="[% line.points %]"/>
  [% END %]

  [% FOREACH place IN frame.map_places %]
    <text class="place-label" x="[% place.x %]" y="[% place.y %]"
          font-size="[% place.font_size %]">[% place.name | html %]</text>
  [% END %]

  <!-- current position + heading, fixed at the centre -->
  <g transform="translate([% frame.map_width / 2 %] [% frame.map_height / 2 %]) rotate([% heading | html %])">
    <polygon points="0,-9 4,7 0,4 -4,7" fill="#1a73e8" stroke="#0b3d91" stroke-width="1"/>
  </g>

</svg>
