<svg viewBox="0 0 120 120" width="140" height="140" role="img" aria-labelledby="mountainTitle">
  <title id="mountainTitle">Altitude</title>
  <!-- Mountain silhouette -->
  <g fill="#111" stroke="none">
    <path d="M10 90 L35 50 L55 70 L75 30 L100 90 Z" />
  </g>

  <text x="60" y="105"
        text-anchor="middle"
        font-size="14"
        font-weight="bold"
        fill="#333">[% frame.altitude | format('%.1f') | html %]m</text>

</svg>
